PORT=4000

# Supabase: copy the "Session pooler" connection string from
# Project Settings → Database → Connection string, and set DATABASE_SSL=true.
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-DB-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
DATABASE_SSL=true

# For a plain local Postgres instead, use e.g.:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/asset_tracking
# DATABASE_SSL=false

JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=8h
CLIENT_ORIGIN=http://localhost:5173
