PORT=4000

# Supabase: copy the "Session pooler" connection string from
# Project Settings → Database → Connection string, and set DATABASE_SSL=true.
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-DB-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
DATABASE_SSL=true

# For a plain local Postgres instead, use e.g.:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/asset_tracking
# DATABASE_SSL=false

JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=8h
CLIENT_ORIGIN=http://localhost:5173

# Supabase Storage (used for document/QR-code uploads instead of local disk,
# required since Vercel's serverless functions have no persistent filesystem).
# Project Settings → API → Project URL / service_role secret.
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=[YOUR-SERVICE-ROLE-KEY]

# Shared secret checked by api/cron/notifications.ts; set the same value here
# and as a Vercel env var so only Vercel Cron can trigger it.
CRON_SECRET=change-this-secret
