# Optional: only needed if the client and API are deployed to different
# domains (e.g. client on Vercel, server on Railway). Leave unset when both
# are served from the same Vercel project — the client then defaults to the
# relative '/api' path (and Vite's dev proxy handles local dev either way).
# VITE_API_URL=https://your-backend-host/api

# Required: used by the browser to upload files directly to Supabase Storage
# (bypassing the API, since serverless functions cap request bodies well
# below the app's upload size limit). The anon/publishable key is safe to
# expose client-side — Project Settings → API.
VITE_SUPABASE_URL=https://[PROJECT-REF].supabase.co
VITE_SUPABASE_ANON_KEY=[YOUR-ANON-OR-PUBLISHABLE-KEY]
